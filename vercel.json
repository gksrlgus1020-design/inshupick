{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "inshupick.kr" }],
      "destination": "https://www.inshupick.kr/$1",
      "permanent": true
    }
  ]
}
